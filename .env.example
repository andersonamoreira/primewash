# Copie este arquivo para ".env" e ajuste os valores antes de rodar "docker compose up -d --build"

# Credenciais do banco de dados PostgreSQL (usadas pelo serviço "db" e pelo "app")
POSTGRES_USER=primewash
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=primewash

# Chave secreta usada pelo Auth.js para assinar sessões. Gere uma nova com:
#   openssl rand -base64 32
AUTH_SECRET=troque-este-valor-por-uma-chave-aleatoria-longa

# Porta exposta no servidor (acesse http://IP_DO_SERVIDOR:PORTA)
APP_PORT=3000

# Integração com o Google Calendar (agenda primewashmoto@gmail.com).
# Veja o passo a passo no README para gerar a conta de serviço do Google Cloud.
# Deixe em branco para manter a integração desativada.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primewashmoto@gmail.com
